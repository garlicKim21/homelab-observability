# =============================================================================
# Basphere Observability - Environment Variables
# =============================================================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env
# =============================================================================

# --- Monitoring VM ---
MONITORING_VM_IP=192.168.2.x

# --- DNS ---
# 내부 DNS 서버 IP (docker-compose.yml에서 참조)
DNS_SERVER=192.168.x.x

# --- Device IPs ---
# config 파일의 <AP_IP>, <OCI_INSTANCE_IP> 등의 플레이스홀더를 실제 값으로 교체하세요
AP_IP=192.168.x.x
OCI_INSTANCE_IP=10.x.x.x

# --- VictoriaMetrics ---
VM_RETENTION_PERIOD=180d

# --- Grafana ---
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme
GF_SERVER_ROOT_URL=https://grafana.basphere.dev
GF_SERVER_DOMAIN=grafana.basphere.dev

# --- Alertmanager / Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# --- vCenter (Phase 2에서 사용) ---
VCENTER_HOST=vcsa.basphere.local
VCENTER_USER=observability-basphere@basphere.local
VCENTER_PASSWORD=changeme

# --- OPNsense (Phase 3에서 사용) ---
# OPNsense Web UI → System → Access → Users → API Keys에서 생성
OPNSENSE_API_KEY=your_api_key_here
OPNSENSE_API_SECRET=your_api_secret_here

# --- SNMP v3 (Phase 4에서 사용) ---
# SNMP v3 인증 정보는 configs/snmp_exporter/snmp.yml에서 직접 설정합니다.
# 장비별 프로필: basphere_v3_des (스위치), basphere_v3_aes (NAS, AP)
