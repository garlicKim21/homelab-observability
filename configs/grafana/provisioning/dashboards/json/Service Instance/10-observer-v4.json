    {
      "id": 5,
      "title": "Active Alerts",
      "description": "Number of currently firing alerts.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
