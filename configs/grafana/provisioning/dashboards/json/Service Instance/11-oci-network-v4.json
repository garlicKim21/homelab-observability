    {
      "id": 11,
      "title": "DRG Traffic (Bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "targets": [
        {
          "expr": "oci_drg_bytes_from{profile=~\"$profile\"}",
          "legendFormat": "{{attachment_type}} {{peer_region}} In",
          "refId": "A"
        },
        {
          "expr": "oci_drg_bytes_to{profile=~\"$profile\"}",
          "legendFormat": "{{attachment_type}} {{peer_region}} Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "showPoints": "never",
            "lineWidth": 1,
            "fillOpacity": 15,
            "spanNulls": false,
            "axisLabel": "In (+) / Out (-)"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/Out$/" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 5] } },
              { "id": "custom.fillOpacity", "value": 10 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
