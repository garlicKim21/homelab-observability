    {
      "id": 11,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 3,
        "x": 0,
        "y": 5
      },
      "options": {
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FADE2A",
                "value": 70
              },
              {
                "color": "#F2495C",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"idle\"}[$__rate_interval])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "CPU Usage by Mode",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 3,
        "y": 5
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "showPoints": "never",
            "lineWidth": 2,
            "fillOpacity": 50,
            "stacking": {
              "mode": "normal"
            },
            "spanNulls": false
          },
          "noValue": "N/A"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "User"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "System"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IO Wait"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9830"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#B877D9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Nice"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Soft IRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#B877D9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Steal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FADE2A"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"user\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"system\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "System",
          "refId": "B"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"iowait\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "IO Wait",
          "refId": "C"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"irq\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "IRQ",
          "refId": "D"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"softirq\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "Soft IRQ",
          "refId": "E"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"nice\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "Nice",
          "refId": "F"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"steal\"}[$__rate_interval])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "Steal",
          "refId": "G"
        }
      ]
    },
