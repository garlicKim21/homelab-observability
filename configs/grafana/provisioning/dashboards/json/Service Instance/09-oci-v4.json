      },
      "panels": []
    },
    {
      "id": 2,
      "title": "OCI Server Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#F2495C"
                },
                "1": {
                  "text": "UP",
                  "color": "#73BF69"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#F2495C",
                "value": null
              },
              {
                "color": "#73BF69",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "N/A"
        }
      },
      "targets": [
        {
          "expr": "up{job=\"oci_node\"}",
          "legendFormat": "OCI Server",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "System Uptime",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
