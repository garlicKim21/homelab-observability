          { "matcher": { "id": "byName", "options": "5m" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }] },
          { "matcher": { "id": "byName", "options": "15m" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }] }
