    {
      "id": 22,
      "title": "Filesystem Usage",
      "description": "Disk usage for root (/) and VictoriaMetrics data partition (/data). The /data partition is critical for time series storage capacity.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 20, "x": 4, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10,
        "namePlacement": "auto",
        "valueMode": "color",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/\"}) * 100",
          "legendFormat": "/ (root)",
          "refId": "A"
        },
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/data\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/data\"}) * 100",
          "legendFormat": "/data (VictoriaMetrics)",
          "refId": "B"
        }
      ]
    },
