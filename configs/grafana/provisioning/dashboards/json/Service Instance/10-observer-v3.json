{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Overview",
      "url": "/d/homelab-overview",
      "type": "link",
      "targetBlank": false,
      "keepTime": true
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["homelab", "observer", "monitoring", "v3"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Observer Monitoring Stack",
  "uid": "observer-v3",
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "VictoriaMetrics",
          "value": "VictoriaMetrics"
        },
        "hide": 2,
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Server Status",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "#F2495C" }, "1": { "text": "UP", "color": "#73BF69" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#73BF69", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Uptime" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "mappings", "value": [] },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "transparent" } },
              { "id": "custom.displayMode", "value": "none" }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "up{job=\"observer_node\"}",
          "legendFormat": "Status",
          "refId": "A"
        },
        {
          "expr": "time() - node_boot_time_seconds{job=\"observer_node\"}",
          "legendFormat": "Uptime",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Running Containers",
      "description": "Number of running containers managed by Docker Compose on the observer node. Expected: 12.",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FADE2A", "value": 10 },
              { "color": "#73BF69", "value": 12 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "count(container_last_seen{job=\"observer_cadvisor\", container_label_com_docker_compose_service=~\".+\"}) or vector(0)",
          "legendFormat": "Containers",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Time Series",
      "description": "Total number of active time series stored in VictoriaMetrics small storage.",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#5794F2" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "#5794F2", "value": null }]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "vm_rows{type=\"storage/small\"}",
          "legendFormat": "Time Series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Alerts",
      "description": "Number of currently firing alerts across all alert rules.",
      "type": "stat",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#F2495C", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "0", "color": "#73BF69" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "legendFormat": "Firing Alerts",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "CPU & Memory",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },
    {
      "id": 11,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 3, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"observer_node\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "CPU by Mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 3, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 50,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "User" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }] },
          { "matcher": { "id": "byName", "options": "System" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }] },
          { "matcher": { "id": "byName", "options": "IOWait" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }] },
          { "matcher": { "id": "byName", "options": "IRQ" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }] },
          { "matcher": { "id": "byName", "options": "SoftIRQ" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#B877D9" } }] },
          { "matcher": { "id": "byName", "options": "Nice" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }] },
          { "matcher": { "id": "byName", "options": "Steal" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF6EB4" } }] },
          { "matcher": { "id": "byName", "options": "Idle" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FFFFFF10" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"user\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"system\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "System",
          "refId": "B"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"iowait\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "IOWait",
          "refId": "C"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"irq\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "IRQ",
          "refId": "D"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"softirq\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "SoftIRQ",
          "refId": "E"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"nice\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "Nice",
          "refId": "F"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"steal\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "Steal",
          "refId": "G"
        }
      ]
    },
    {
      "id": 13,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 3, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 75 },
              { "color": "#F2495C", "value": 90 }
            ]
          },
          "color": { "mode": "thresholds" },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"observer_node\"} / node_memory_MemTotal_bytes{job=\"observer_node\"}) * 100",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 50,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" },
            "showPoints": "never"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }] },
          { "matcher": { "id": "byName", "options": "Cached" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }] },
          { "matcher": { "id": "byName", "options": "Buffers" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }] },
          { "matcher": { "id": "byName", "options": "Free" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#C8F2C2" } }] }
        ]
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"observer_node\"} - node_memory_MemAvailable_bytes{job=\"observer_node\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_Cached_bytes{job=\"observer_node\"}",
          "legendFormat": "Cached",
          "refId": "B"
        },
        {
          "expr": "node_memory_Buffers_bytes{job=\"observer_node\"}",
          "legendFormat": "Buffers",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemFree_bytes{job=\"observer_node\"}",
          "legendFormat": "Free",
          "refId": "D"
        }
      ]
    },
    {
