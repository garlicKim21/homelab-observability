        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(probe_success{job=\"blackbox_http\"})",
          "legendFormat": "Up",
          "refId": "A"
        },
        {
          "expr": "count(probe_success{job=\"blackbox_http\"})",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto"
      }
    },
    {
      "id": 5,
      "title": "SSL Certificate Expiry",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "targets": [
        {
          "expr": "(min(probe_ssl_earliest_cert_expiry{job=\"blackbox_http\"}) - time()) / 86400",
          "legendFormat": "Days",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 14
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto"
      }
    },
    {
      "id": 10,
      "title": "CPU & Memory",
      "type": "row",
