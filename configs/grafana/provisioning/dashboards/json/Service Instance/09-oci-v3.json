    {
      "id": 11,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 16,
        "w": 3,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"oci_node\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdMarkers": true,
        "showThresholdLabels": false
      }
    },
    {
      "id": 12,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 16,
        "w": 9,
        "x": 3,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"user\"}[5m])) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"system\"}[5m])) * 100",
          "legendFormat": "System",
          "refId": "B"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IOWait",
          "refId": "C"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"irq\"}[5m])) * 100",
          "legendFormat": "IRQ",
          "refId": "D"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"softirq\"}[5m])) * 100",
          "legendFormat": "SoftIRQ",
          "refId": "E"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"nice\"}[5m])) * 100",
          "legendFormat": "Nice",
          "refId": "F"
        },
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"steal\"}[5m])) * 100",
          "legendFormat": "Steal",
          "refId": "G"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "User"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "System"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IOWait"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FADE2A"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9830"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "SoftIRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#B877D9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Nice"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Steal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF6EB4"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
