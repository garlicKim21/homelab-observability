{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "oci",
    "cloud",
    "ratatosk",
    "v2"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "OCI Cloud (ratatosk.io) V2",
  "uid": "oci-cloud-v2",
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "VictoriaMetrics",
          "value": "VictoriaMetrics"
        },
        "hide": 2,
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_VICTORIAMETRICS}"
        },
        "query": "label_values(container_last_seen{job=\"oci_cadvisor\", name=~\"ratatosk-.+\", container_label_com_docker_compose_service=~\".+\"}, name)",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "label": "Container",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Instance Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "up{job=\"oci_node\"}",
          "legendFormat": "Status",
          "refId": "A"
        },
        {
          "expr": "time() - node_boot_time_seconds{job=\"oci_node\"}",
          "legendFormat": "Uptime",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "DOWN",
                        "color": "red",
                        "index": 0
                      },
                      "1": {
                        "text": "UP",
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uptime"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 4,
      "title": "Running Containers",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "count(container_last_seen{job=\"oci_cadvisor\", name=~\".+\", container_label_com_docker_compose_service=~\".+\"}) or vector(0)",
          "legendFormat": "Containers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "CPU & Memory",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 3,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"oci_node\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 3,
        "y": 6
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"oci_node\", mode!=\"idle\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"oci_node\"})) * 100",
          "legendFormat": "{{ mode }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 3,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"oci_node\"} / node_memory_MemTotal_bytes{job=\"oci_node\"}) * 100",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 15,
        "y": 6
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"oci_node\"} - node_memory_MemAvailable_bytes{job=\"oci_node\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_Cached_bytes{job=\"oci_node\"}",
          "legendFormat": "Cached"
        },
        {
          "expr": "node_memory_Buffers_bytes{job=\"oci_node\"}",
          "legendFormat": "Buffers"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"oci_node\"}",
          "legendFormat": "Available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 60,
      "title": "System Detail",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      }
    },
    {
      "id": 13,
      "title": "Load Average",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "node_load1{job=\"oci_node\"}",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5{job=\"oci_node\"}",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15{job=\"oci_node\"}",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 17,
      "title": "Filesystem Usage",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 14
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"oci_node\", fstype!~\"tmpfs|devtmpfs|overlay\"} / node_filesystem_size_bytes{job=\"oci_node\", fstype!~\"tmpfs|devtmpfs|overlay\"}) * 100",
          "legendFormat": "{{ mountpoint }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 9,
      "title": "Instance Info",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "targets": [
        {
          "expr": "node_uname_info{job=\"oci_node\"}",
          "legendFormat": "{{ nodename }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "1": {
                  "text": "ARM64 4C/24G"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "options": {
        "colorMode": "none",
        "textMode": "name"
      },
      "description": "OCI Singapore | ratatosk.io | ARM 4C/24G"
    },
    {
      "id": 14,
      "title": "Disk & Network",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      }
    },
    {
      "id": 15,
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"oci_node\", device!~\"lo|veth.*|docker.*|br-.*\"}[5m]) * 8",
          "legendFormat": "{{ device }} Rx"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{job=\"oci_node\", device!~\"lo|veth.*|docker.*|br-.*\"}[5m]) * 8",
          "legendFormat": "{{ device }} Tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Rx$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Tx$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 16,
      "title": "Disk I/O",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"oci_node\"}[5m])",
          "legendFormat": "{{ device }} Read"
        },
        {
          "expr": "-rate(node_disk_written_bytes_total{job=\"oci_node\"}[5m])",
          "legendFormat": "{{ device }} Write"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 15
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 20,
      "title": "Application Services",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      }
    },
    {
      "id": 21,
      "title": "ratatosk.io (Next.js)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_http\", instance=\"https://ratatosk.io\"}",
          "legendFormat": "ratatosk.io"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 22,
      "title": "Umami (Analytics)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 30
      },
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_internal\", service=\"umami\"}",
          "legendFormat": "Umami"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
