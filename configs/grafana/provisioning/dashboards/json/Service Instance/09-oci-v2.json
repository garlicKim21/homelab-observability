        "textMode": "value"
      }
    },
    {
      "id": 24,
      "title": "SSL Certificate Expiry",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 30
      },
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox_http\"} - time()) / 86400",
          "legendFormat": "Days Left"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 14
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value"
      }
    },
    {
      "id": 25,
      "title": "HTTP Status Code",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 30
      },
      "targets": [
        {
          "expr": "probe_http_status_code{job=\"blackbox_http\"}",
          "legendFormat": "ratatosk.io"
        },
        {
          "expr": "probe_http_status_code{job=\"blackbox_internal\", service=\"umami\"}",
          "legendFormat": "umami"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 400
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value"
      }
    },
    {
      "id": 26,
      "title": "Response Time",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "expr": "probe_duration_seconds{job=\"blackbox_http\"}",
          "legendFormat": "ratatosk.io"
        },
        {
          "expr": "probe_duration_seconds{job=\"blackbox_internal\", service=\"umami\"}",
          "legendFormat": "umami"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 27,
      "title": "Response Time Phases (ratatosk.io)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", phase=\"resolve\"}",
          "legendFormat": "DNS Resolve"
        },
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", phase=\"connect\"}",
          "legendFormat": "TCP Connect"
        },
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", phase=\"tls\"}",
          "legendFormat": "TLS Handshake"
        },
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", phase=\"processing\"}",
          "legendFormat": "Server Processing"
        },
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", phase=\"transfer\"}",
          "legendFormat": "Content Transfer"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            },
            "lineWidth": 1
          }
        }
      },
      "options": {
