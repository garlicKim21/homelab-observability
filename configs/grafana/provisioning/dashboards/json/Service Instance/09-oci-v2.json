          "gridPos": { "h": 7, "w": 12, "x": 0, "y": 91 },
          "targets": [
            { "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"oci_cadvisor\", name=\"$container\"}[5m]))", "legendFormat": "Usage", "refId": "A" },
