{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Overview",
      "url": "/d/homelab-overview",
      "type": "link",
      "targetBlank": false,
      "keepTime": true
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "observer",
    "monitoring",
    "v2"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Observer Server V2",
  "uid": "observer-v2",
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "VictoriaMetrics",
          "value": "VictoriaMetrics"
        },
        "hide": 2,
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_VICTORIAMETRICS}"
        },
        "query": "label_values(container_last_seen{job=\"observer_cadvisor\", container_label_com_docker_compose_service=~\".+\"}, name)",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "label": "Container",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Server Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 3,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "up{job=\"observer_node\"}",
          "legendFormat": "Status",
          "refId": "A"
        },
        {
          "expr": "time() - node_boot_time_seconds{job=\"observer_node\"}",
          "legendFormat": "Uptime",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "DOWN",
                        "color": "red",
                        "index": 0
                      },
                      "1": {
                        "text": "UP",
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Uptime"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      }
    },
    {
      "id": 4,
      "title": "Running Containers",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 3,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "count(container_last_seen{job=\"observer_cadvisor\", name=~\".+\", container_label_com_docker_compose_service=~\".+\"}) or vector(0)",
          "legendFormat": "Containers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "CPU & Memory",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 6,
        "w": 3,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 3,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(node_cpu_seconds_total{job=\"observer_node\", mode!=\"idle\"}[5m])) / count(count by (cpu) (node_cpu_seconds_total{job=\"observer_node\"})) * 100",
          "legendFormat": "{{ mode }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 6,
        "w": 3,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"observer_node\"} / node_memory_MemTotal_bytes{job=\"observer_node\"}) * 100",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 6,
        "w": 9,
        "x": 15,
        "y": 5
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"observer_node\"} - node_memory_MemAvailable_bytes{job=\"observer_node\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_Cached_bytes{job=\"observer_node\"}",
          "legendFormat": "Cached"
        },
        {
          "expr": "node_memory_Buffers_bytes{job=\"observer_node\"}",
          "legendFormat": "Buffers"
        },
        {
          "expr": "node_memory_MemAvailable_bytes{job=\"observer_node\"}",
          "legendFormat": "Available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 70,
      "title": "System Detail",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      }
    },
    {
      "id": 12,
      "title": "Load Average",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "node_load1{job=\"observer_node\"}",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5{job=\"observer_node\"}",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15{job=\"observer_node\"}",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 71,
      "title": "Disk Usage",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/\"}) * 100",
          "legendFormat": "Root",
          "refId": "A"
        },
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/data\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/data\"}) * 100",
          "legendFormat": "Data",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 72,
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"observer_node\", device!~\"lo|docker.*|br-.*|veth.*\"}[5m]) * 8",
          "legendFormat": "{{ device }} Rx",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{job=\"observer_node\", device!~\"lo|docker.*|br-.*|veth.*\"}[5m]) * 8",
          "legendFormat": "{{ device }} Tx",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Rx$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*Tx$"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 20,
      "title": "Monitoring Stack Services",
