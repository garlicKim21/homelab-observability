{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "AP Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "up{job=\"snmp_ap\", instance=\"<AP_IP>\"}", "legendFormat": "AP" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "sysUpTime{job=\"snmp_ap\"} / 100", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "none" }
    },
    {
      "title": "Active Interfaces",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "count(ifOperStatus{job=\"snmp_ap\"} == 1)", "legendFormat": "Active" }],
      "options": { "colorMode": "value" }
    },
    {
      "title": "WiFi Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "WiFi Traffic (wl0 - 2.4GHz)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"wl0\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"wl0\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "WiFi Traffic (wl1 - 5GHz)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"wl1\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"wl1\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Wired Traffic",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "Ethernet Traffic (eth1)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"eth1\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"eth1\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "All Interface Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\"}[5m]) * 8", "legendFormat": "{{ ifDescr }} In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\"}[5m]) * 8", "legendFormat": "{{ ifDescr }} Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "title": "Port Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "rate(ifInErrors{job=\"snmp_ap\"}[5m])", "legendFormat": "{{ ifDescr }} InErr" },
        { "expr": "rate(ifOutErrors{job=\"snmp_ap\"}[5m])", "legendFormat": "{{ ifDescr }} OutErr" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Interface Status",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "ifOperStatus{job=\"snmp_ap\"}", "format": "table", "instant": true, "refId": "status" },
        { "expr": "ifSpeed{job=\"snmp_ap\"}", "format": "table", "instant": true, "refId": "speed" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "ifDescr" } }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value #status" }, "properties": [{ "id": "mappings", "value": [{ "options": { "1": { "text": "UP", "color": "green" }, "2": { "text": "DOWN", "color": "red" } }, "type": "value" }] }, { "id": "displayName", "value": "Status" }] },
          { "matcher": { "id": "byName", "options": "Value #speed" }, "properties": [{ "id": "unit", "value": "bps" }, { "id": "displayName", "value": "Speed" }] }
        ]
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["homelab", "ap", "wifi"],
  "templating": {
    "list": [
      { "current": { "selected": false, "text": "VictoriaMetrics", "value": "VictoriaMetrics" }, "hide": 2, "name": "DS_VICTORIAMETRICS", "type": "datasource", "query": "prometheus" }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "ipTime AP",
  "uid": "iptime-ap"
}
