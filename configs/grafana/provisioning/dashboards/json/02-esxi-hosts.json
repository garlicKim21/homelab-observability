    {
      "title": "CPU & Memory",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "title": "Host CPU Usage (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [{ "expr": "vmware_host_cpu_usage / vmware_host_cpu_max * 100", "legendFormat": "{{ host_name }}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 10 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      }
    },
    {
      "title": "Host Memory Usage (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "targets": [{ "expr": "vmware_host_memory_usage / vmware_host_memory_max * 100", "legendFormat": "{{ host_name }}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 10 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }] }
        }
      }
    },
    {
      "title": "Advanced Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "collapsed": false
    },
    {
      "title": "Host CPU Demand",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
      "targets": [{ "expr": "vmware_host_cpu_demand_average", "legendFormat": "{{ host_name }}" }],
      "fieldConfig": { "defaults": { "unit": "rotmhz", "min": 0, "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Host Memory Active",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
      "targets": [{ "expr": "vmware_host_mem_active_average", "legendFormat": "{{ host_name }}" }],
      "fieldConfig": { "defaults": { "unit": "deckbytes", "min": 0, "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Host Memory Swap",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 42 },
      "targets": [
        { "expr": "vmware_host_mem_swapin_average", "legendFormat": "{{ host_name }} SwapIn" },
        { "expr": "vmware_host_mem_swapout_average", "legendFormat": "{{ host_name }} SwapOut" }
      ],
      "fieldConfig": { "defaults": { "unit": "KBs", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "Host Network Rx/Tx",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 50 },
      "targets": [
        { "expr": "vmware_host_net_bytesRx_average{job=\"vmware\"} * 1024", "legendFormat": "{{ host_name }} Rx" },
        { "expr": "-vmware_host_net_bytesTx_average{job=\"vmware\"} * 1024", "legendFormat": "{{ host_name }} Tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Host Network Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 50 },
      "targets": [
        { "expr": "vmware_host_net_errorsRx_summation", "legendFormat": "{{ host_name }} ErrRx" },
        { "expr": "vmware_host_net_errorsTx_summation", "legendFormat": "{{ host_name }} ErrTx" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Disk & Storage",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "collapsed": false
    },
    {
      "title": "Host Disk I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 58 },
      "targets": [
        { "expr": "vmware_host_disk_read_average", "legendFormat": "{{ host_name }} Read" },
        { "expr": "vmware_host_disk_write_average", "legendFormat": "{{ host_name }} Write" }
      ],
      "fieldConfig": { "defaults": { "unit": "KBs", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Datastores",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 65 },
      "collapsed": false
    },
    {
      "title": "Datastore Capacity",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 66 },
      "targets": [{ "expr": "vmware_datastore_capacity_size", "legendFormat": "{{ ds_name }}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "title": "Datastore Free Space",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 66 },
      "targets": [{ "expr": "vmware_datastore_freespace_size", "legendFormat": "{{ ds_name }}" }],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 10737418240 }, { "color": "green", "value": 53687091200 }] }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "title": "Datastore Provisioned",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 66 },
      "targets": [{ "expr": "vmware_datastore_provisoned_size", "legendFormat": "{{ ds_name }}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "value" }
    },
    {
      "title": "Host Details",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 72 },
      "collapsed": false
    },
    {
      "title": "ESXi Hosts",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 73 },
      "targets": [
        { "expr": "vmware_host_power_state", "format": "table", "instant": true, "refId": "power" },
        { "expr": "vmware_host_cpu_usage / vmware_host_cpu_max * 100", "format": "table", "instant": true, "refId": "cpu" },
        { "expr": "vmware_host_memory_usage / vmware_host_memory_max * 100", "format": "table", "instant": true, "refId": "mem" },
        { "expr": "vmware_host_num_cpu", "format": "table", "instant": true, "refId": "cpucount" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "host_name" } }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #power" },
            "properties": [
              { "id": "displayName", "value": "Power" },
              { "id": "mappings", "value": [{ "options": { "0": { "text": "OFF", "color": "red" }, "1": { "text": "ON", "color": "green" } }, "type": "value" }] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #cpu" },
            "properties": [
              { "id": "displayName", "value": "CPU %" },
