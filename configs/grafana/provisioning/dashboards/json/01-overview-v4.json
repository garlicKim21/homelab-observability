    {
      "id": 11,
      "title": "CPU Utilization by Device",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "OPNsense",
          "refId": "A"
        },
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"observer_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "Observer",
          "refId": "B"
        },
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"oci_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "OCI",
          "refId": "C"
        },
        {
          "expr": "avg(vmware_host_cpu_usage) / avg(vmware_host_cpu_max) * 100",
          "legendFormat": "ESXi Cluster",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#73BF69",
                "value": null
              },
              {
                "color": "#FADE2A",
                "value": 70
              },
              {
                "color": "#F2495C",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "N/A"
        }
