{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    { "title": "Overview", "url": "/d/homelab-overview", "type": "link", "targetBlank": false, "keepTime": true }
  ],
  "panels": [
    {
      "title": "Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Server Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "up{job=\"observer_node\"}", "legendFormat": "Observer" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "node_time_seconds{job=\"observer_node\"} - node_boot_time_seconds{job=\"observer_node\"}", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "none", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Running Containers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "count(container_last_seen{job=\"observer_cadvisor\", name=~\".+\", container_label_com_docker_compose_service=~\".+\"}) or vector(0)", "legendFormat": "Containers" }],
      "options": { "colorMode": "value" }
    },
    {
      "title": "System",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"observer_node\", mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes{job=\"observer_node\"} / node_memory_MemTotal_bytes{job=\"observer_node\"}) * 100", "legendFormat": "Memory" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      }
    },
    {
      "title": "OS Disk (/)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/\"}) * 100", "legendFormat": "Root (/)" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
        }
      }
    },
    {
      "title": "Data Disk (/data)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{job=\"observer_node\", mountpoint=\"/data\"} / node_filesystem_size_bytes{job=\"observer_node\", mountpoint=\"/data\"}) * 100", "legendFormat": "Data (/data)" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 85 }] }
        }
      }
    },
    {
      "title": "Load Average",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "node_load1{job=\"observer_node\"}", "legendFormat": "1m" },
        { "expr": "node_load5{job=\"observer_node\"}", "legendFormat": "5m" },
        { "expr": "node_load15{job=\"observer_node\"}", "legendFormat": "15m" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"observer_node\"} - node_memory_MemAvailable_bytes{job=\"observer_node\"}", "legendFormat": "Used" },
        { "expr": "node_memory_Cached_bytes{job=\"observer_node\"}", "legendFormat": "Cached" },
        { "expr": "node_memory_Buffers_bytes{job=\"observer_node\"}", "legendFormat": "Buffers" },
        { "expr": "node_memory_MemAvailable_bytes{job=\"observer_node\"}", "legendFormat": "Available" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Monitoring Stack",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "collapsed": false
    },
    {
      "title": "VictoriaMetrics",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 20 },
      "targets": [{ "expr": "up{job=\"victoriametrics\"}", "legendFormat": "VM" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Grafana",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 20 },
      "targets": [{ "expr": "up{job=\"grafana\"}", "legendFormat": "Grafana" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "vmalert",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 20 },
      "targets": [{ "expr": "up{job=\"vmalert\"}", "legendFormat": "vmalert" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Alertmanager",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 20 },
      "targets": [{ "expr": "up{job=\"alertmanager\"}", "legendFormat": "AM" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" }
    },
    {
      "title": "Active Time Series",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 20 },
      "targets": [{ "expr": "vm_rows{type=\"storage/small\"}", "legendFormat": "Series" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "none", "graphMode": "area", "textMode": "value" }
    },
    {
      "title": "Ingestion Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 24 },
      "targets": [{ "expr": "rate(vm_rows_inserted_total[5m])", "legendFormat": "{{ type }}" }],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Storage Size",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 24 },
      "targets": [{ "expr": "vm_data_size_bytes", "legendFormat": "{{ type }}" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "VM Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 24 },
      "targets": [{ "expr": "process_resident_memory_bytes{job=\"victoriametrics\"}", "legendFormat": "RSS" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Network",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 32 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"observer_node\", device!~\"lo|docker.*|br-.*|veth.*\"}[5m]) * 8", "legendFormat": "{{ device }} Rx" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"observer_node\", device!~\"lo|docker.*|br-.*|veth.*\"}[5m]) * 8", "legendFormat": "{{ device }} Tx" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "Disk I/O",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "title": "Disk I/O Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 40 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Read", "refId": "A" },
        { "expr": "-rate(node_disk_written_bytes_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Write", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Disk IOPS",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "expr": "rate(node_disk_reads_completed_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Read", "refId": "A" },
        { "expr": "-rate(node_disk_writes_completed_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Write", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Disk I/O Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 47 },
      "targets": [
        { "expr": "rate(node_disk_io_time_seconds_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m]) * 100", "legendFormat": "{{ device }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 15 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        }
      }
    },
    {
      "title": "Disk Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 47 },
      "targets": [
        { "expr": "rate(node_disk_read_time_seconds_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m]) / rate(node_disk_reads_completed_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Read", "refId": "A" },
        { "expr": "rate(node_disk_write_time_seconds_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m]) / rate(node_disk_writes_completed_total{job=\"observer_node\", device!~\"loop.*|dm-.*\"}[5m])", "legendFormat": "{{ device }} Write", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.02 }, { "color": "red", "value": 0.05 }] }
        }
      }
    },
    {
      "title": "VictoriaMetrics Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "collapsed": false
    },
    {
      "title": "Slow Inserts Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 55 },
      "targets": [
        { "expr": "rate(vm_slow_row_inserts_total{job=\"victoriametrics\"}[5m])", "legendFormat": "Slow Inserts" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 15 },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 }] },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Query Duration (p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 55 },
      "targets": [
        { "expr": "vm_request_duration_seconds{job=\"victoriametrics\", quantile=\"0.99\"}", "legendFormat": "p99 {{ path }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Merge Operations",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 55 },
      "targets": [
        { "expr": "rate(vm_merges_total{job=\"victoriametrics\"}[5m])", "legendFormat": "{{ type }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Pending Rows",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 62 },
      "targets": [
        { "expr": "vm_pending_rows{job=\"victoriametrics\", type=\"storage\"}", "legendFormat": "Pending Rows" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Cache Requests & Misses",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 62 },
      "targets": [
        { "expr": "rate(vm_cache_requests_total{job=\"victoriametrics\"}[5m])", "legendFormat": "{{ type }} Requests", "refId": "A" },
        { "expr": "rate(vm_cache_misses_total{job=\"victoriametrics\"}[5m])", "legendFormat": "{{ type }} Misses", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Active Merges",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 62 },
      "targets": [
        { "expr": "vm_active_merges{job=\"victoriametrics\"}", "legendFormat": "{{ type }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 15 } } }
    },
    {
      "title": "Docker Containers",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 },
      "collapsed": false
    },
    {
      "title": "Total Container CPU",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 70 },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"observer_cadvisor\", name=~\".+\"}[5m]))", "legendFormat": "Usage", "refId": "A" },
        { "expr": "sum(max by (name) (container_spec_cpu_quota{job=\"observer_cadvisor\", name=~\".+\"} > 0) / max by (name) (container_spec_cpu_period{job=\"observer_cadvisor\", name=~\".+\"}))", "legendFormat": "Limit", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "decimals": 2,
          "custom": { "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Total Container Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 70 },
      "targets": [
        { "expr": "sum(container_memory_usage_bytes{job=\"observer_cadvisor\", name=~\".+\"})", "legendFormat": "Usage", "refId": "A" },
        { "expr": "node_memory_MemTotal_bytes{job=\"observer_node\"}", "legendFormat": "Host Total", "refId": "B" },
        { "expr": "sum(max by (name) (container_spec_memory_limit_bytes{job=\"observer_cadvisor\", name=~\".+\"} > 0))", "legendFormat": "Limit", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "C" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "$container",
      "type": "row",
      "repeat": "container",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 77 }
    },
    {
      "title": "$container CPU",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 78 },
      "targets": [
        { "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"observer_cadvisor\", name=\"$container\"}[5m]))", "legendFormat": "Usage", "refId": "A" },
