    {
      "id": 22,
      "title": "Guest Storage",
      "type": "row",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "panels": [
        {
          "id": 23,
          "title": "Guest Disk Usage",
          "type": "bargauge",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "gridPos": { "h": 7, "w": 24, "x": 0, "y": 39 },
          "targets": [
            {
              "expr": "(vmware_vm_guest_disk_capacity - vmware_vm_guest_disk_free) / vmware_vm_guest_disk_capacity * 100",
              "legendFormat": "{{vm_name}} {{disk_path}}",
              "refId": "A",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 75 },
                  { "color": "red", "value": 90 }
                ]
              },
              "mappings": []
            },
            "overrides": []
          },
          "options": {
            "orientation": "horizontal",
            "displayMode": "gradient",
            "showUnfilled": true,
            "reduceOptions": { "calcs": ["lastNotNull"] }
          }
        }
      ]
    },
    {
      "id": 24,
      "title": "Inventory",
      "type": "row",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "panels": [
        {
          "id": 25,
          "title": "VM Inventory",
          "type": "table",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
          "targets": [
            {
              "expr": "vmware_vm_power_state",
              "legendFormat": "",
              "refId": "power",
              "format": "table",
              "instant": true
            },
            {
              "expr": "vmware_vm_num_cpu",
              "legendFormat": "",
              "refId": "cpu",
              "format": "table",
              "instant": true
            },
            {
              "expr": "vmware_vm_memory_max",
              "legendFormat": "",
              "refId": "memory",
              "format": "table",
              "instant": true
            }
          ],
          "fieldConfig": {
            "defaults": {
              "custom": {
                "displayMode": "auto",
                "cellOptions": { "type": "auto" }
              }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Value #power" },
                "properties": [
                  { "id": "displayName", "value": "Power State" },
                  {
                    "id": "mappings",
                    "value": [
                      {
                        "type": "value",
                        "options": {
                          "0": { "text": "Off", "color": "red" },
                          "1": { "text": "On", "color": "green" }
                        }
                      }
                    ]
                  },
                  { "id": "custom.displayMode", "value": "color-background" }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "Value #cpu" },
                "properties": [
                  { "id": "displayName", "value": "vCPU" }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "Value #memory" },
                "properties": [
                  { "id": "displayName", "value": "Memory" },
                  { "id": "unit", "value": "bytes" }
                ]
              }
            ]
          },
          "options": {
            "showHeader": true,
            "cellHeight": "sm",
            "sortBy": [{ "displayName": "vm_name", "desc": false }]
          },
          "transformations": [
            { "id": "merge", "options": {} },
            {
              "id": "filterFieldsByName",
              "options": {
                "include": {
                  "names": [
                    "vm_name",
                    "host_name",
                    "Value #power",
                    "Value #cpu",
                    "Value #memory"
                  ]
                }
              }
            },
            {
              "id": "organize",
              "options": {
                "renameByName": {
                  "vm_name": "VM",
                  "host_name": "Host"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
