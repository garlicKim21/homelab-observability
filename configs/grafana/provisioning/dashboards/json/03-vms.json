    {
      "id": 61,
      "title": "Guest Disk Usage",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 50
      },
      "targets": [
        {
          "expr": "(vmware_vm_guest_disk_capacity - vmware_vm_guest_disk_free) / vmware_vm_guest_disk_capacity * 100",
          "legendFormat": "{{vm_name}} {{disk_path}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "mappings": []
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 62,
      "title": "Guest Disk Free",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 50
      },
      "targets": [
        {
          "expr": "vmware_vm_guest_disk_capacity",
          "legendFormat": "",
          "refId": "capacity",
          "format": "table",
          "instant": true
        },
        {
          "expr": "vmware_vm_guest_disk_free",
          "legendFormat": "",
          "refId": "free",
          "format": "table",
          "instant": true
        },
        {
          "expr": "(vmware_vm_guest_disk_capacity - vmware_vm_guest_disk_free) / vmware_vm_guest_disk_capacity * 100",
          "legendFormat": "",
          "refId": "usedpct",
          "format": "table",
          "instant": true
        }
      ],
      "description": "Guest OS disk capacity, free space, and used percentage per VM per mount point.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #capacity"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Capacity"
              },
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #free"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Free"
              },
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #usedpct"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Used %"
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 75
                    },
                    {
                      "color": "red",
                      "value": 90
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "Used %",
            "desc": true
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "vm_name",
                "disk_path",
                "Value #capacity",
                "Value #free",
                "Value #usedpct"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "vm_name": "VM",
              "disk_path": "Mount"
            }
          }
        }
      ]
    },
