    {
      "id": 32,
      "title": "Interface Status",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "expr": "ifOperStatus{job=\"snmp_ap\"}",
          "format": "table",
          "instant": true,
          "refId": "status"
        },
        {
          "expr": "ifSpeed{job=\"snmp_ap\"}",
          "format": "table",
          "instant": true,
          "refId": "speed"
        },
        {
          "expr": "rate(ifHCInOctets{job=\"snmp_ap\"}[5m]) * 8",
          "format": "table",
          "instant": true,
          "refId": "in"
        },
        {
          "expr": "rate(ifHCOutOctets{job=\"snmp_ap\"}[5m]) * 8",
          "format": "table",
          "instant": true,
          "refId": "out"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "ifDescr"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "ifDescr": "Interface",
              "Value #status": "Status",
              "Value #speed": "Speed",
              "Value #in": "In Traffic",
              "Value #out": "Out Traffic"
            }
          }
        }
      ],
      "options": {
        "cellHeight": "sm",
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "UP",
                        "color": "green",
                        "index": 0
                      },
                      "2": {
                        "text": "DOWN",
                        "color": "red",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Speed"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bps"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "In Traffic"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bps"
