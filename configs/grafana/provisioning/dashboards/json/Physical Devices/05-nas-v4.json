    {
      "id": 30,
      "title": "Disk Health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Disk Status",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "synology_disk_status{job=\"snmp_nas\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "synology_disk_temperature{job=\"snmp_nas\"}",
          "legendFormat": "{{diskID}}",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "N/A",
          "custom": {
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "Normal",
                        "color": "#73BF69"
                      },
                      "2": {
                        "text": "Initialized",
                        "color": "#5794F2"
                      },
                      "3": {
                        "text": "NotInitialized",
                        "color": "#FADE2A"
                      },
                      "4": {
                        "text": "SystemPartitionFailed",
                        "color": "#F2495C"
                      },
                      "5": {
                        "text": "Crashed",
                        "color": "#F2495C"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Temperature (°C)"
              },
              {
                "id": "unit",
                "value": "celsius"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "#73BF69",
                      "value": null
                    },
                    {
                      "color": "#FADE2A",
                      "value": 40
                    },
                    {
                      "color": "#F2495C",
                      "value": 50
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "diskID",
            "desc": false
          }
        ]
      },
      "transformations": [
        {
