      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "#F2495C",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "#73BF69",
                  "index": 1
