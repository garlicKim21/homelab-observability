    {
      "id": 11,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"user\"}[5m])) * 100",
          "legendFormat": "User"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"system\"}[5m])) * 100",
          "legendFormat": "System"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"nice\"}[5m])) * 100",
          "legendFormat": "Nice"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IOWait"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"irq\"}[5m])) * 100",
          "legendFormat": "IRQ"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"softirq\"}[5m])) * 100",
          "legendFormat": "SoftIRQ"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"steal\"}[5m])) * 100",
          "legendFormat": "Steal"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "User"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "System"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IOWait"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "yellow"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "SoftIRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "purple"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Nice"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "cyan"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Steal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "pink"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
