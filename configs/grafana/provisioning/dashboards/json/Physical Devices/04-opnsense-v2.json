        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "opnsense_instance": true
            },
            "renameByName": {
              "name": "Gateway",
              "address": "Address",
              "Value": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Down",
                        "color": "red",
                        "index": 0
                      },
                      "1": {
                        "text": "Up",
                        "color": "green",
                        "index": 1
                      },
                      "2": {
                        "text": "Unknown",
                        "color": "orange",
                        "index": 2
                      },
                      "3": {
                        "text": "Pending",
                        "color": "yellow",
                        "index": 3
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
