{
  "uid": "synology-nas-v2",
  "title": "Synology NAS V2",
  "tags": ["homelab", "nas", "synology", "v2"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "graphTooltip": 1,
  "editable": true,
  "annotations": { "list": [] },
  "links": [],
  "fiscalYearStartMonth": 0,
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "hide": 2,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "label": "VictoriaMetrics"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "System Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "NAS Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "up{job=\"snmp_nas\"}",
          "legendFormat": "NAS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "System Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "synology_system_status{job=\"snmp_nas\"}",
          "legendFormat": "System",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "Normal", "color": "green", "index": 0 },
                "2": { "text": "FAILED", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "System Temp",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "synology_system_temperature{job=\"snmp_nas\"}",
          "legendFormat": "Temperature",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 80,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 45 },
              { "color": "red", "value": 60 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "title": "Power",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "synology_power_status{job=\"snmp_nas\"}",
          "legendFormat": "Power",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "OK", "color": "green", "index": 0 },
                "2": { "text": "FAIL", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "System Fan",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "synology_system_fan_status{job=\"snmp_nas\"}",
          "legendFormat": "System Fan",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "OK", "color": "green", "index": 0 },
                "2": { "text": "FAIL", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
