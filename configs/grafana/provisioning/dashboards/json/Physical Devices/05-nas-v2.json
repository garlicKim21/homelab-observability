{
  "uid": "synology-nas-v2",
  "title": "Synology NAS V2",
  "tags": ["homelab", "nas", "synology", "v2"],
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "graphTooltip": 1,
  "editable": true,
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "hide": 2,
        "label": "VictoriaMetrics"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "System Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "NAS Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "up{job=\"snmp_nas\"}", "legendFormat": "NAS", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "System Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "synology_system_status{job=\"snmp_nas\"}", "legendFormat": "System", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Normal", "color": "green", "index": 0 }, "2": { "text": "FAILED", "color": "red", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "System Temp",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "synology_system_temperature{job=\"snmp_nas\"}", "legendFormat": "Temperature", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius", "min": 0, "max": 80,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 45 }, { "color": "red", "value": 60 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "id": 5,
      "title": "Power",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "synology_power_status{job=\"snmp_nas\"}", "legendFormat": "Power", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "OK", "color": "green", "index": 0 }, "2": { "text": "FAIL", "color": "red", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "System Fan",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "synology_system_fan_status{job=\"snmp_nas\"}", "legendFormat": "System Fan", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "OK", "color": "green", "index": 0 }, "2": { "text": "FAIL", "color": "red", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "CPU Fan",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "synology_cpu_fan_status{job=\"snmp_nas\"}", "legendFormat": "CPU Fan", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "OK", "color": "green", "index": 0 }, "2": { "text": "FAIL", "color": "red", "index": 1 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "CPU & Memory",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 6 },
      "targets": [{ "expr": "100 - synology_cpu_idle{job=\"snmp_nas\"}", "legendFormat": "CPU", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "id": 10,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 9, "x": 3, "y": 6 },
      "targets": [
        { "expr": "synology_cpu_user{job=\"snmp_nas\"}", "legendFormat": "User", "refId": "A" },
        { "expr": "synology_cpu_system{job=\"snmp_nas\"}", "legendFormat": "System", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 50, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "User" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "System" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 3, "x": 12, "y": 6 },
      "targets": [{ "expr": "(1 - (synology_memory_available{job=\"snmp_nas\"} + synology_memory_buffer{job=\"snmp_nas\"} + synology_memory_cached{job=\"snmp_nas\"}) / synology_memory_total{job=\"snmp_nas\"}) * 100", "legendFormat": "Memory", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true }
    },
    {
      "id": 12,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 6 },
      "targets": [
        { "expr": "(synology_memory_total{job=\"snmp_nas\"} - synology_memory_available{job=\"snmp_nas\"} - synology_memory_buffer{job=\"snmp_nas\"} - synology_memory_cached{job=\"snmp_nas\"}) * 1024", "legendFormat": "Used", "refId": "A" },
        { "expr": "synology_memory_cached{job=\"snmp_nas\"} * 1024", "legendFormat": "Cached", "refId": "B" },
        { "expr": "synology_memory_buffer{job=\"snmp_nas\"} * 1024", "legendFormat": "Buffer", "refId": "C" },
        { "expr": "synology_memory_available{job=\"snmp_nas\"} * 1024", "legendFormat": "Available", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 50, "stacking": { "mode": "normal", "group": "A" }, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Cached" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "Buffer" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "cyan" } }] },
          { "matcher": { "id": "byName", "options": "Available" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13,
      "title": "Storage Pools",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false
    },
    {
      "id": 14,
      "title": "RAID Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 13 },
      "targets": [{ "expr": "synology_raid_status{job=\"snmp_nas\"}", "legendFormat": "{{ raidName }}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "1": { "text": "Normal", "color": "green", "index": 0 }, "2": { "text": "Repairing", "color": "yellow", "index": 1 }, "11": { "text": "DEGRADED", "color": "orange", "index": 2 }, "12": { "text": "CRASHED", "color": "red", "index": 3 } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 15,
      "title": "RAID Usage",
      "description": "Volume 1/2: usable volumes, Storage Pool 1: HDD (personal), Storage Pool 2: SSD (vSphere iSCSI)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 10, "x": 4, "y": 13 },
      "targets": [
        { "expr": "(synology_raid_total_size{raidName=\"Volume 1\"} - synology_raid_free_size{raidName=\"Volume 1\"}) / synology_raid_total_size{raidName=\"Volume 1\"} * 100", "legendFormat": "Volume 1 (Personal HDD)", "refId": "A" },
        { "expr": "(synology_raid_total_size{raidName=\"Volume 2\"} - synology_raid_free_size{raidName=\"Volume 2\"}) / synology_raid_total_size{raidName=\"Volume 2\"} * 100", "legendFormat": "Volume 2 (vSphere SSD)", "refId": "B" },
        { "expr": "(synology_raid_total_size{raidName=\"Storage Pool 1\"} - synology_raid_free_size{raidName=\"Storage Pool 1\"}) / synology_raid_total_size{raidName=\"Storage Pool 1\"} * 100", "legendFormat": "Storage Pool 1 (HDD)", "refId": "C" },
        { "expr": "(synology_raid_total_size{raidName=\"Storage Pool 2\"} - synology_raid_free_size{raidName=\"Storage Pool 2\"}) / synology_raid_total_size{raidName=\"Storage Pool 2\"} * 100", "legendFormat": "Storage Pool 2 (SSD)", "refId": "D" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },
    {
      "id": 16,
      "title": "RAID Free Space",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 14, "y": 13 },
      "targets": [
        { "expr": "synology_raid_free_size{raidName=\"Volume 1\"}", "legendFormat": "Volume 1", "refId": "A" },
        { "expr": "synology_raid_free_size{raidName=\"Volume 2\"}", "legendFormat": "Volume 2", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "colorMode": "none", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 17,
      "title": "RAID Usage Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 13 },
      "targets": [
        { "expr": "(synology_raid_total_size{raidName=\"Volume 1\"} - synology_raid_free_size{raidName=\"Volume 1\"}) / synology_raid_total_size{raidName=\"Volume 1\"} * 100", "legendFormat": "Volume 1", "refId": "A" },
        { "expr": "(synology_raid_total_size{raidName=\"Volume 2\"} - synology_raid_free_size{raidName=\"Volume 2\"}) / synology_raid_total_size{raidName=\"Volume 2\"} * 100", "legendFormat": "Volume 2", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "fillOpacity": 15, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 18,
      "title": "Disk Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 19,
      "title": "Disk Status",
      "description": "Disk 1-2: HDD (Pool 1, Personal), Disk 3-5: SSD (Pool 2, vSphere)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 19 },
      "targets": [
        { "expr": "synology_disk_status{job=\"snmp_nas\"}", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "device": true,
              "device_type": true,
              "diskIndex": true
            },
            "indexByName": {
              "diskID": 0,
              "diskModel": 1,
              "Value": 2
            },
            "renameByName": {
              "diskID": "Disk",
              "diskModel": "Model",
              "Value": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "mappings", "value": [{ "type": "value", "options": { "1": { "text": "Normal", "color": "green", "index": 0 }, "2": { "text": "Initialized", "color": "blue", "index": 1 }, "4": { "text": "SysPartFail", "color": "red", "index": 2 }, "5": { "text": "Crashed", "color": "red", "index": 3 } } }] },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Disk", "desc": false }] }
    },
    {
      "id": 20,
      "title": "Disk Temperature",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "targets": [{ "expr": "synology_disk_temperature{job=\"snmp_nas\"}", "legendFormat": "{{ diskID }} ({{ diskModel }})", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "fillOpacity": 10, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 40 }, { "color": "red", "value": 50 }] }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 21,
      "title": "Storage I/O",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 22,
      "title": "IOPS - Pool 1 HDD (sda, sdb)",
      "description": "Personal storage (Disk 1-2, HDD RAID1)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 26 },
      "targets": [
        { "expr": "rate(synology_storageio_reads{job=\"snmp_nas\", storageioDevice=~\"sd[ab]\"}[5m])", "legendFormat": "{{ storageioDevice }} Reads", "refId": "A" },
        { "expr": "rate(synology_storageio_writes{job=\"snmp_nas\", storageioDevice=~\"sd[ab]\"}[5m])", "legendFormat": "{{ storageioDevice }} Writes", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops", "custom": { "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 23,
      "title": "IOPS - Pool 2 SSD (sdc, sdd, sde)",
      "description": "vSphere shared storage (Disk 3-5, SSD RAID5)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 26 },
      "targets": [
        { "expr": "rate(synology_storageio_reads{job=\"snmp_nas\", storageioDevice=~\"sd[cde]\"}[5m])", "legendFormat": "{{ storageioDevice }} Reads", "refId": "A" },
        { "expr": "rate(synology_storageio_writes{job=\"snmp_nas\", storageioDevice=~\"sd[cde]\"}[5m])", "legendFormat": "{{ storageioDevice }} Writes", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops", "custom": { "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 24,
      "title": "I/O Load - Pool 1 HDD",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 26 },
      "targets": [{ "expr": "synology_storageio_load{job=\"snmp_nas\", storageioDevice=~\"sd[ab]\"}", "legendFormat": "{{ storageioDevice }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 25,
      "title": "I/O Load - Pool 2 SSD",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 26 },
      "targets": [{ "expr": "synology_storageio_load{job=\"snmp_nas\", storageioDevice=~\"sd[cde]\"}", "legendFormat": "{{ storageioDevice }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 26,
      "title": "Network - Management (eth0)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false
    },
    {
      "id": 27,
      "title": "Management / External Traffic (eth0)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 34 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_nas\", ifDescr=\"eth0\"}[5m]) * 8", "legendFormat": "eth0 In", "refId": "A" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_nas\", ifDescr=\"eth0\"}[5m]) * 8", "legendFormat": "eth0 Out", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20, "showPoints": "never" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 28,
      "title": "Network - iSCSI / vSphere (eth1-3)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "id": 29,
      "title": "iSCSI MPIO Traffic (eth1, eth2, eth3)",
