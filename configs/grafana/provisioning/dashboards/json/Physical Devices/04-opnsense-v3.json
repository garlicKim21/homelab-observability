          "expr": "(1 - node_filesystem_avail_bytes{job=\"opnsense_node\", fstype!~\"tmpfs|devfs|procfs|nullfs\"} / node_filesystem_size_bytes{job=\"opnsense_node\", fstype!~\"tmpfs|devfs|procfs|nullfs\"}) * 100",
