    {
      "id": 15,
      "title": "Port Info",
      "type": "row",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "panels": [
        {
          "id": 16,
          "title": "Port Status",
          "type": "table",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
              "expr": "ifOperStatus{job=\"snmp_switch\"}",
              "format": "table",
              "instant": true,
              "legendFormat": "__auto",
              "refId": "status"
            },
            {
              "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
              "expr": "ifSpeed{job=\"snmp_switch\"}",
              "format": "table",
              "instant": true,
              "legendFormat": "__auto",
              "refId": "speed"
            },
            {
              "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
              "expr": "ifDescr{job=\"snmp_switch\"}",
              "format": "table",
              "instant": true,
              "legendFormat": "__auto",
              "refId": "descr"
            }
          ],
          "transformations": [
            {
              "id": "seriesToColumns",
              "options": { "byField": "ifDescr" }
            },
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "Time 1": true,
                  "Time 2": true,
                  "Time 3": true,
                  "__name__": true,
                  "__name__ 1": true,
                  "__name__ 2": true,
                  "__name__ 3": true,
                  "job": true,
                  "job 1": true,
                  "job 2": true,
                  "job 3": true,
                  "instance": true,
                  "instance 1": true,
                  "instance 2": true,
                  "instance 3": true
                },
                "renameByName": {
                  "ifDescr": "Port",
                  "Value #status": "Status",
                  "Value #speed": "Speed"
                }
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [{ "color": "green", "value": null }]
              }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "Status" },
                "properties": [
                  {
                    "id": "mappings",
                    "value": [
                      {
                        "type": "value",
                        "options": {
                          "1": { "text": "UP", "color": "green", "index": 0 },
                          "2": { "text": "DOWN", "color": "red", "index": 1 }
                        }
                      }
                    ]
                  },
                  { "id": "custom.displayMode", "value": "color-background" }
                ]
              },
              {
                "matcher": { "id": "byName", "options": "Speed" },
                "properties": [
                  { "id": "unit", "value": "bps" }
                ]
              }
            ]
          },
          "options": {
            "cellHeight": "sm",
            "footer": { "show": false, "reducer": ["sum"], "fields": "" },
            "showHeader": true,
            "sortBy": [{ "displayName": "Port", "desc": false }]
          }
        }
      ]
    },

