      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "rate(ifHCInOctets{job=\"snmp_switch\",ifIndex=~\"$port\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} In",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
          "expr": "-rate(ifHCOutOctets{job=\"snmp_switch\",ifIndex=~\"$port\"}[5m]) * 8",
          "legendFormat": "{{ifDescr}} Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "axisCenteredZero": true,
            "fillOpacity": 20,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },

