{
  "uid": "opnsense-firewall",
  "title": "OPNsense Firewall",
  "tags": ["homelab", "opnsense", "firewall"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "annotations": {
    "list": []
  },
  "links": [],
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "System Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "title": "Firewall Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "up{job=\"opnsense\"}",
          "legendFormat": "Status",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Node Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "up{job=\"opnsense_node\"}",
          "legendFormat": "Status",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{job=\"opnsense_node\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Active States",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "opnsense_firewall_states_count",
          "legendFormat": "States",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Gateway Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "opnsense_gateways_status",
          "legendFormat": "{{ name }}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Offline", "color": "red", "index": 0 },
                "1": { "text": "Online", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Services Running",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "count(opnsense_services_status == 1)",
          "legendFormat": "Running",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "CPU & Memory",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "panels": []
    },
    {
      "id": 9,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 3, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "CPU by Mode",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 9, "x": 3, "y": 6 },
      "targets": [
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"user\"}[5m])) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"system\"}[5m])) * 100",
          "legendFormat": "System",
          "refId": "B"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IOWait",
          "refId": "C"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"irq\"}[5m])) * 100",
          "legendFormat": "IRQ",
          "refId": "D"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"nice\"}[5m])) * 100",
          "legendFormat": "Nice",
          "refId": "E"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"idle\"}[5m])) * 100",
          "legendFormat": "Idle",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "User" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "System" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF6D00" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "IOWait" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "IRQ" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#B877D9" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Nice" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Idle" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 3, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"opnsense_node\"} / node_memory_MemTotal_bytes{job=\"opnsense_node\"}) * 100",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 9, "x": 15, "y": 6 },
      "targets": [
        {
          "expr": "node_memory_size_bytes{job=\"opnsense_node\"} - node_memory_free_bytes{job=\"opnsense_node\"} - node_memory_inactive_bytes{job=\"opnsense_node\"} - node_memory_cache_bytes{job=\"opnsense_node\"} - node_memory_buffer_bytes{job=\"opnsense_node\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_cache_bytes{job=\"opnsense_node\"}",
          "legendFormat": "Cached",
          "refId": "B"
        },
        {
          "expr": "node_memory_buffer_bytes{job=\"opnsense_node\"}",
          "legendFormat": "Buffer",
          "refId": "C"
        },
        {
          "expr": "node_memory_free_bytes{job=\"opnsense_node\"} + node_memory_inactive_bytes{job=\"opnsense_node\"}",
          "legendFormat": "Available",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Cached" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Buffer" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#37872D" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 13,
      "title": "Load & Filesystem",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "panels": []
    },
    {
      "id": 14,
      "title": "Load Average",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "node_load1{job=\"opnsense_node\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{job=\"opnsense_node\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{job=\"opnsense_node\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "1m" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5m" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FADE2A" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "15m" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 15,
      "title": "Filesystem Usage",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 14 },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{job=\"opnsense_node\", fstype!~\"tmpfs|devfs|procfs|nullfs\"} / node_filesystem_size_bytes{job=\"opnsense_node\", fstype!~\"tmpfs|devfs|procfs|nullfs\"}) * 100",
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Disk I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 14 },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"opnsense_node\",device=\"ada0\"}[5m])",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "expr": "-rate(node_disk_write_bytes_total{job=\"opnsense_node\",device=\"ada0\"}[5m])",
          "legendFormat": "Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Read" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Write" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 17,
      "title": "Firewall Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "panels": []
    },
    {
      "id": 18,
      "title": "Firewall States",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "opnsense_firewall_states_count",
          "legendFormat": "Active States",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 19,
      "title": "Blocked Packets by Interface",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "rate(opnsense_firewall_in_ipv4_block_packets[5m])",
          "legendFormat": "{{ interface }} In Block",
          "refId": "A"
        },
        {
          "expr": "rate(opnsense_firewall_out_ipv4_block_packets[5m])",
          "legendFormat": "{{ interface }} Out Block",
          "refId": "B"
        },
        {
          "expr": "rate(opnsense_firewall_in_ipv4_pass_packets[5m])",
          "legendFormat": "{{ interface }} In Pass",
          "refId": "C"
        },
        {
          "expr": "rate(opnsense_firewall_out_ipv4_pass_packets[5m])",
          "legendFormat": "{{ interface }} Out Pass",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 20,
      "title": "Interface Traffic",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "panels": []
    },
    {
      "id": 21,
      "title": "WAN (igc5) Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\",device=\"igc5\"}[5m]) * 8",
          "legendFormat": "In",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{job=\"opnsense_node\",device=\"igc5\"}[5m]) * 8",
          "legendFormat": "Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "In" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Out" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 22,
      "title": "InfraNET (lagg0) Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 30 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\",device=\"lagg0\"}[5m]) * 8",
          "legendFormat": "In",
