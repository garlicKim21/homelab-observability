    {
      "id": 10,
      "title": "CPU",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 9,
        "x": 3,
        "y": 6
      },
      "targets": [
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"user\"}[5m])) * 100",
          "legendFormat": "User",
          "refId": "A"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"system\"}[5m])) * 100",
          "legendFormat": "System",
          "refId": "B"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"irq\"}[5m])) * 100",
          "legendFormat": "IRQ",
          "refId": "D"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"nice\"}[5m])) * 100",
          "legendFormat": "Nice",
          "refId": "E"
        },
        {
          "expr": "avg by (mode)(rate(node_cpu_seconds_total{job=\"opnsense_node\",mode=\"idle\"}[5m])) * 100",
          "legendFormat": "Idle",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "User"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "System"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF6D00"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IRQ"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#B877D9"
