{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "TP-Link SG2218 Switch V2",
  "uid": "sg2218-switch-v2",
  "tags": ["homelab", "switch", "network", "v2"],
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "VictoriaMetrics", "value": "VictoriaMetrics" },
        "hide": 2,
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [

    {
      "title": "Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 1,
      "title": "Switch Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "up{job=\"snmp_switch\"}",
          "legendFormat": "SG2218",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },

    {
      "id": 2,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "sysUpTime{job=\"snmp_switch\"} / 100",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },

    {
      "id": 3,
      "title": "Active Ports",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "count(ifOperStatus{job=\"snmp_switch\"} == 1)",
          "legendFormat": "Active",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },

    {
      "id": 4,
      "title": "Total Ports",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "count(ifOperStatus{job=\"snmp_switch\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },

    {
      "id": 5,
      "title": "Error Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "sum(rate(ifInErrors{job=\"snmp_switch\"}[5m]))",
          "legendFormat": "In Errors/s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "sum(rate(ifOutErrors{job=\"snmp_switch\"}[5m]))",
          "legendFormat": "Out Errors/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },

    {
      "title": "CPU & Memory",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "id": 6,
      "title": "CPU",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 3, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_cpu_1m{job=\"snmp_switch_system\"}",
          "legendFormat": "CPU (1m)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 7,
      "title": "CPU History",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 9, "x": 3, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_cpu_5s{job=\"snmp_switch_system\"}",
          "legendFormat": "CPU (5s)",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_cpu_1m{job=\"snmp_switch_system\"}",
          "legendFormat": "CPU (1m)",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_cpu_5m{job=\"snmp_switch_system\"}",
          "legendFormat": "CPU (5m)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU (5s)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "light-red" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU (1m)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU (5m)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 8,
      "title": "Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 3, "x": 12, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_memory_usage{job=\"snmp_switch_system\"}",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },

    {
      "id": 9,
      "title": "Memory History",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "tplink_memory_usage{job=\"snmp_switch_system\"}",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "title": "Port Traffic",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }
    },

    {
      "id": 10,
      "title": "Port Traffic Top 10",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "topk(10, rate(ifHCInOctets{job=\"snmp_switch\"}[5m]) * 8)",
          "legendFormat": "{{ ifDescr }} In",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "topk(10, -rate(ifHCOutOctets{job=\"snmp_switch\"}[5m]) * 8)",
          "legendFormat": "{{ ifDescr }} Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 11,
      "title": "Port Bandwidth Utilization",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "rate(ifHCInOctets{job=\"snmp_switch\"}[5m]) * 8 / ifSpeed{job=\"snmp_switch\"} * 100 > 0",
          "legendFormat": "{{ ifDescr }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 75 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      }
    },

    {
      "title": "Errors & Discards",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 }
    },

    {
      "id": 12,
      "title": "Port Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "rate(ifInErrors{job=\"snmp_switch\"}[5m])",
          "legendFormat": "{{ ifDescr }} In",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "rate(ifOutErrors{job=\"snmp_switch\"}[5m])",
          "legendFormat": "{{ ifDescr }} Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "id": 13,
      "title": "Port Discards",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "rate(ifInDiscards{job=\"snmp_switch\"}[5m])",
          "legendFormat": "{{ ifDescr }} In",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "rate(ifOutDiscards{job=\"snmp_switch\"}[5m])",
          "legendFormat": "{{ ifDescr }} Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },

    {
      "title": "Port Info",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }
    },

    {
      "id": 14,
      "title": "Port Overview",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "ifOperStatus{job=\"snmp_switch\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "status"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "ifSpeed{job=\"snmp_switch\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "speed"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "ifDescr" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "instance": true,
              "instance 1": true,
              "instance 2": true
            },
            "renameByName": {
              "ifDescr": "Port",
              "Value #status": "Status",
              "Value #speed": "Speed"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": { "text": "UP", "color": "green", "index": 0 },
                      "2": { "text": "DOWN", "color": "red", "index": 1 }
                    }
                  }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Speed" },
            "properties": [
              { "id": "unit", "value": "bps" }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "fields": "" },
        "showHeader": true,
        "sortBy": [{ "displayName": "Port", "desc": false }]
      }
    }

  ]
}
