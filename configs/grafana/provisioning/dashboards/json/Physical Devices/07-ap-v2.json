{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["homelab", "ap", "wifi", "v2"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "ipTime AP V2",
  "uid": "iptime-ap-v2",
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "VictoriaMetrics", "value": "VictoriaMetrics" },
        "hide": 2,
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "Status",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },

    {
      "id": 2,
      "title": "AP Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        { "expr": "up{job=\"snmp_ap\"}", "legendFormat": "AP" }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [
        { "expr": "sysUpTime{job=\"snmp_ap\"} / 100", "legendFormat": "Uptime" }
      ],
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },

    {
      "id": 4,
      "title": "Active Interfaces",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [
        { "expr": "count(ifOperStatus{job=\"snmp_ap\"} == 1)", "legendFormat": "Active" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "title": "Total Throughput",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 1 },
      "targets": [
        { "expr": "sum(rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=~\"wl.*\"}[5m])) * 8",  "legendFormat": "WiFi In" },
        { "expr": "sum(rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=~\"wl.*\"}[5m])) * 8", "legendFormat": "WiFi Out" }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },

    {
      "id": 10,
      "title": "WiFi Traffic",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },

    {
      "id": 11,
      "title": "2.4GHz WiFi (wl0)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"wl0\"}[5m]) * 8",  "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"wl0\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "In" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Out" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 12,
      "title": "5GHz WiFi (wl1)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"wl1\"}[5m]) * 8",  "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"wl1\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "In" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Out" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 20,
      "title": "Wired Traffic",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },

    {
      "id": 21,
      "title": "Ethernet (eth1)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\", ifDescr=\"eth1\"}[5m]) * 8",  "legendFormat": "In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\", ifDescr=\"eth1\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 22,
      "title": "All Interfaces",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "rate(ifHCInOctets{job=\"snmp_ap\"}[5m]) * 8",  "legendFormat": "{{ ifDescr }} In" },
        { "expr": "-rate(ifHCOutOctets{job=\"snmp_ap\"}[5m]) * 8", "legendFormat": "{{ ifDescr }} Out" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 15, "lineWidth": 1 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 30,
      "title": "Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },

    {
      "id": 31,
      "title": "Interface Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "targets": [
        { "expr": "rate(ifInErrors{job=\"snmp_ap\"}[5m])",  "legendFormat": "{{ ifDescr }} In" },
        { "expr": "rate(ifOutErrors{job=\"snmp_ap\"}[5m])", "legendFormat": "{{ ifDescr }} Out" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 32,
      "title": "Interface Status",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "targets": [
        { "expr": "ifOperStatus{job=\"snmp_ap\"}", "format": "table", "instant": true, "refId": "status" },
        { "expr": "ifSpeed{job=\"snmp_ap\"}",      "format": "table", "instant": true, "refId": "speed" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "ifDescr" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "ifDescr": "Interface"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": { "text": "UP",   "color": "green", "index": 0 },
                      "2": { "text": "DOWN", "color": "red",   "index": 1 }
                    }
                  }
                ]
              },
              { "id": "displayName", "value": "Status" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #speed" },
            "properties": [
              { "id": "unit",        "value": "bps" },
              { "id": "displayName", "value": "Speed" }
            ]
          }
        ]
      }
    }

  ]
}
