    {
      "id": 31,
      "title": "Volume 1 IOPS (HDD)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "expr": "sum(rate(synology_storageio_reads{storageioDevice=~\"sda|sdb\"}[5m]))",
          "legendFormat": "Read",
          "refId": "A"
        },
        {
          "expr": "-sum(rate(synology_storageio_writes{storageioDevice=~\"sda|sdb\"}[5m]))",
          "legendFormat": "Write",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "color": {
            "mode": "fixed",
            "fixedColor": "#5794F2"
          },
          "noValue": "0",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "pointSize": 5,
            "spanNulls": true,
            "axisLabel": "Read (+) / Write (-)"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#B877D9"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    5,
                    5
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
