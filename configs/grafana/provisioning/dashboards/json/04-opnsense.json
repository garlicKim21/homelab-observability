{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "System (node_exporter)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"opnsense_node\", mode=\"idle\"}[5m])) * 100)", "legendFormat": "CPU" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 80 }] } } }
    },
    {
      "title": "Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "(1 - (node_memory_free_bytes{job=\"opnsense_node\"} + node_memory_inactive_bytes{job=\"opnsense_node\"} + node_memory_cache_bytes{job=\"opnsense_node\"} + node_memory_buffer_bytes{job=\"opnsense_node\"}) / node_memory_size_bytes{job=\"opnsense_node\"}) * 100", "legendFormat": "Memory" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "title": "Disk /",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{job=\"opnsense_node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"opnsense_node\", mountpoint=\"/\"}) * 100", "legendFormat": "Root" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }] } } }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "node_time_seconds{job=\"opnsense_node\"} - node_boot_time_seconds{job=\"opnsense_node\"}", "legendFormat": "Uptime" }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "colorMode": "none" }
    },
    {
      "title": "Load Average",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 1 },
      "targets": [
        { "expr": "node_load1{job=\"opnsense_node\"}", "legendFormat": "1m" },
        { "expr": "node_load5{job=\"opnsense_node\"}", "legendFormat": "5m" },
        { "expr": "node_load15{job=\"opnsense_node\"}", "legendFormat": "15m" }
      ],
      "options": { "colorMode": "none" }
    },
    {
      "title": "Services",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 1 },
      "targets": [
        { "expr": "opnsense_services_running_total", "legendFormat": "Running" },
        { "expr": "opnsense_services_stopped_total", "legendFormat": "Stopped" }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "title": "Firewall (opnsense-exporter)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "title": "Firewall Blocked Packets (by interface)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        { "expr": "opnsense_firewall_in_ipv4_block_packets", "legendFormat": "{{ interface }} In Block" },
        { "expr": "opnsense_firewall_out_ipv4_block_packets", "legendFormat": "{{ interface }} Out Block" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Firewall Passed Packets (by interface)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "targets": [
        { "expr": "opnsense_firewall_in_ipv4_pass_packets", "legendFormat": "{{ interface }} In Pass" },
        { "expr": "opnsense_firewall_out_ipv4_pass_packets", "legendFormat": "{{ interface }} Out Pass" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Services Status",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "targets": [{ "expr": "opnsense_services_status", "legendFormat": "{{ name }}", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "opnsense_instance": true }, "renameByName": { "name": "Service", "description": "Description", "Value": "Status" } } }
      ],
      "fieldConfig": { "overrides": [{ "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "Stopped", "color": "red" }, "1": { "text": "Running", "color": "green" } } }] }] }] }
    },
    {
      "title": "Interface Traffic (node_exporter)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "title": "WAN (igc5) Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 22 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\", device=\"igc5\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"opnsense_node\", device=\"igc5\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "InfraNET (lagg0) Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 22 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\", device=\"lagg0\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"opnsense_node\", device=\"lagg0\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "HomeNET (igc3) Traffic",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 22 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\", device=\"igc3\"}[5m]) * 8", "legendFormat": "In" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"opnsense_node\", device=\"igc3\"}[5m]) * 8", "legendFormat": "Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 20 } } }
    },
    {
      "title": "All Interfaces",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 29 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"opnsense_node\"}[5m]) * 8", "legendFormat": "{{ device }} In" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"opnsense_node\"}[5m]) * 8", "legendFormat": "{{ device }} Out" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Gateway (opnsense-exporter)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "collapsed": false
    },
    {
      "title": "Gateway RTT",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 37 },
      "targets": [{ "expr": "opnsense_gateways_rtt_milliseconds", "legendFormat": "{{ name }}" }],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Gateway Packet Loss",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 37 },
      "targets": [{ "expr": "opnsense_gateways_loss_percentage", "legendFormat": "{{ name }}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "custom": { "fillOpacity": 10 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "title": "Gateway Status",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 44 },
      "targets": [{ "expr": "opnsense_gateways_status", "legendFormat": "{{ name }}", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "opnsense_instance": true }, "renameByName": { "name": "Gateway", "address": "Address", "Value": "Status" } } }
      ],
      "fieldConfig": { "overrides": [{ "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" }, "2": { "text": "Unknown", "color": "orange" }, "3": { "text": "Pending", "color": "yellow" } } }] }] }] }
    },
    {
      "title": "Firewall Logs (Loki)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "collapsed": false
    },
    {
      "title": "OPNsense Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 50 },
      "targets": [{ "expr": "{device_type=\"firewall\"}", "legendFormat": "" }],
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending" }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["homelab", "opnsense", "firewall"],
  "templating": {
    "list": [
      { "current": { "selected": false, "text": "VictoriaMetrics", "value": "VictoriaMetrics" }, "hide": 2, "name": "DS_VICTORIAMETRICS", "type": "datasource", "query": "prometheus" }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "title": "OPNsense Firewall",
  "uid": "opnsense-firewall"
}
