    {
      "title": "Response Time vs Container CPU (Correlation)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 76
      },
      "targets": [
        {
          "expr": "probe_http_duration_seconds{job=\"blackbox_http\", instance=\"https://ratatosk.io\", phase=\"processing\"}",
          "legendFormat": "Server Processing (s)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"oci_cadvisor\", name=~\"ratatosk-.+\"}[5m])) * 100",
          "legendFormat": "ratatosk Total CPU (%)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{job=\"oci_cadvisor\", name=\"ratatosk-app\"}[5m])) * 100",
          "legendFormat": "ratatosk-app CPU (%)",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "A"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.axisPlacement",
                "value": "left"
              },
              {
                "id": "custom.axisLabel",
                "value": "Response Time"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "CPU Usage"
              },
              {
                "id": "custom.fillOpacity",
                "value": 5
              }
            ]
          },
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "C"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.fillOpacity",
                "value": 5
              }
            ]
          }
        ]
      },
      "description": "Server Processing 스파이크와 Container CPU 사용률 상관 분석. batch-poller(5분) 또는 daily-pipeline(03:00)과의 경합 패턴 확인용."
    },
