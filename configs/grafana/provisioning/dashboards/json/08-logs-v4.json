                "value": 10
              },
              {
                "color": "#F2495C",
                "value": 50
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
