    {
      "id": 2,
      "title": "Log Volume by Source",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "description": "Log event count per device source over time.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "sum by (device_type)(count_over_time({device_type=~\"$device_type\", host=~\"$host\"}[$__interval]))",
          "legendFormat": "{{ device_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 50,
            "lineWidth": 0,
            "barAlignment": 0,
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "N/A"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum",
            "lastNotNull"
          ]
        }
      }
    },
