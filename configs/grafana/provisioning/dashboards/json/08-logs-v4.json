    {
      "id": 51,
      "title": "Log Rate",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "description": "현재 초당 로그 수집 속도",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "sum(rate({device_type=~\".+\"}[5m]))",
          "legendFormat": "Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#F2495C",
                "value": null
              },
              {
                "color": "#73BF69",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "noValue": "0"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 52,
      "title": "Error Rate",
      "type": "stat",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "description": "5분간 error 이상 로그 건수",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "sum(count_over_time({device_type=~\".+\", severity=~\"error|err|crit|critical|emerg|alert\"}[5m]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
