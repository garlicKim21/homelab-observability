        {
          "expr": "100 - synology_cpu_idle{job=\"snmp_nas\"}",
          "legendFormat": "NAS",
          "refId": "B"
        },
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"observer_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "Observer",
          "refId": "C"
        },
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"oci_node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "OCI",
          "refId": "D"
