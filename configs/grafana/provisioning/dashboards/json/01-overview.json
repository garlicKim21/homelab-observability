    {
      "id": 15,
      "title": "CPU Utilization by Device",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "VictoriaMetrics"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"opnsense_node\"}[5m])) * 100",
          "legendFormat": "OPNsense",
          "refId": "A"
        },
        {
          "expr": "synology_cpu_user{job=\"snmp_nas\"} + synology_cpu_system{job=\"snmp_nas\"}",
          "legendFormat": "NAS",
          "refId": "B"
        },
        {
          "expr": "tplink_cpu_1m{job=\"snmp_switch_system\"}",
          "legendFormat": "Switch",
          "refId": "C"
        },
        {
          "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"observer_node\"}[5m])) * 100",
          "legendFormat": "Observer",
          "refId": "D"
        },
        {
          "expr": "100 - avg(rate(node_cpu_seconds_total{mode=\"idle\",job=\"oci_node\"}[5m])) * 100",
          "legendFormat": "OCI",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
