              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "minVizWidth": 8,
        "minVizHeight": 16,
        "namePlacement": "auto",
        "valueMode": "color"
      }
    },
