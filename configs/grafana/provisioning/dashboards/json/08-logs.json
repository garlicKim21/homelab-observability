{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Log Volume",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "title": "Log Volume by Severity",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "description": "Log event count per severity level over the selected time range. Stacked bars show relative contribution of each severity.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "sum by (severity)(count_over_time({device_type=~\"$device_type\"}[$__interval]))",
          "legendFormat": "{{ severity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0,
            "barAlignment": 0,
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "showPoints": "never",
            "spanNulls": false
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "emerg"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#C4162A",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "crit"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "err"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF9830",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warning"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FADE2A",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "notice"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8AB8FF",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#8F8F8F",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      }
    },
    {
      "id": 4,
      "title": "Log Stream",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "Loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "expr": "{device_type=~\"$device_type\", host=~\"$host\"} |~ \"$search\" | severity=~\"$severity\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 5,
      "title": "Error & Critical Logs",
      "type": "row",
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "panels": [
        {
          "id": 6,
          "title": "Error & Critical Stream",
          "type": "logs",
          "datasource": {
            "type": "loki",
            "uid": "Loki"
          },
          "description": "Filtered view showing only emergency, critical, and error severity logs across all selected device types.",
          "gridPos": {
            "h": 12,
            "w": 24,
            "x": 0,
            "y": 21
          },
          "targets": [
            {
              "datasource": {
                "type": "loki",
                "uid": "Loki"
              },
              "expr": "{device_type=~\"$device_type\"} | severity=~\"err|crit|emerg\"",
              "legendFormat": "",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "showCommonLabels": false,
            "wrapLogMessage": true,
            "prettifyLogMessage": false,
            "enableLogDetails": true,
            "sortOrder": "Descending",
            "dedupStrategy": "none"
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "logs",
    "loki"
  ],
  "templating": {
    "list": [
      {
        "name": "device_type",
        "label": "Device Type",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "Firewall",
            "value": "firewall"
          },
          {
            "selected": false,
            "text": "ESXi",
            "value": "esxi"
          },
          {
            "selected": false,
            "text": "NAS",
            "value": "nas"
          }
        ],
        "query": "firewall,esxi,nas",
        "hide": 0,
        "refresh": 0
      },
      {
        "name": "severity",
        "label": "Severity",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": "$__all"
          },
          {
            "selected": false,
            "text": "Emergency",
            "value": "emerg"
          },
          {
            "selected": false,
            "text": "Critical",
            "value": "crit"
          },
          {
            "selected": false,
            "text": "Error",
            "value": "err"
          },
          {
            "selected": false,
            "text": "Warning",
            "value": "warning"
          },
          {
            "selected": false,
            "text": "Notice",
            "value": "notice"
          },
          {
            "selected": false,
            "text": "Info",
            "value": "info"
          },
          {
            "selected": false,
            "text": "Debug",
            "value": "debug"
          }
        ],
        "query": "emerg,crit,err,warning,notice,info,debug",
        "hide": 0,
        "refresh": 0
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "Loki"
        },
        "query": "label_values({device_type=~\"$device_type\"}, host)",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "hide": 0,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "query": ""
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Log Explorer",
  "uid": "logs-explorer"
}